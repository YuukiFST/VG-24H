DJANGO_SECRET_KEY=troque-por-uma-chave-segura
DJANGO_DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=portal_vg
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Neon: use o banco "neondb" (ou o nome que aparecer no painel), host sem postgres://
# POSTGRES_DB=neondb
# POSTGRES_USER=neondb_owner
# POSTGRES_PASSWORD=cole_a_senha_do_neon
