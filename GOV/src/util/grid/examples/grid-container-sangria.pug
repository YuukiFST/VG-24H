extends ../../../partial/pug/isolate
include ../../../components/checkbox/checkbox

block content
  p Neste exemplo, alguns bloco tem o fundo com sangria.
  +checkbox("Ver a margem").pb-3x#margem

  figure.m-0(style="position: relative;")
    img(src="https://www.gov.br/ds/background-card.98fb75c15858969c.png" alt="Imagem de fundo para fins de demonstração" style="max-height: 200px; width: 100%;")
    figcaption
      .container
        .my-2x(style="position: absolute; bottom: 0;")
          p A legenda da imagem fica dentro de um container

  .container.sangria
    .bg-pure-0.py-6x
      p.m-0 Conteúdo sem sangria.

  .py-6x.bg-blue-10
    .container
      p.m-0 Conteúdo no fundo azul.

  .container.sangria
    .bg-pure-0.py-6x
      p.m-0 Outro conteúdo sem sangria.

  .py-6x.bg-yellow-5
    .container
      p.m-0 Conteúdo no fundo amarelo.

  script.
    const checkbox = document.getElementById('margem');
    checkbox.addEventListener('change', () => {
      document.querySelectorAll('.sangria').forEach(el => {
        el.classList.toggle('bg-green-cool-vivid-10', checkbox.checked);
      });
    });