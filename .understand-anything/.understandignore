# .understandignore — patterns for files/dirs to exclude from analysis
# Syntax: same as .gitignore (globs, # comments, ! negation, trailing / for dirs)

# Built-in defaults (always excluded unless negated):
#   node_modules/, .git/, dist/, build/, obj/, *.lock, *.min.js, etc.

# --- Project-specific exclusions ---
AGENTS.md
CONTEXT.md
skills-lock.json
start.py
server.log

# --- Dirs that aren't application code ---
GOV/
docs/
.agents/
.skills/
.antigravity/
.gemini/
.git_backup2/

# --- Python cache ---
__pycache__/
backend/**/__pycache__/
*.pyc

# --- Environments ---
.venv/
venv/
env/
backend/.venv/

# --- IDE / Tools ---
.vscode/
.cursor/
.idea/

# --- Media / Static (generated) ---
media/
backend/staticfiles/

# --- Sensitive ---
.env
.env.*
!.env.example
backend/.env

# --- Logs ---
*.log

# --- Others ---
rewrite*.sh
db_users_out.txt
error_log.txt
pyvenv.cfg
